flowchart TD
    %% Definisi Gaya (Opsional tapi bikin rapi)
    classDef startEnd fill:#f96,stroke:#333,stroke-width:2px;
    classDef process fill:#bbf,stroke:#333,stroke-width:1px;
    classDef decision fill:#ff9,stroke:#333,stroke-width:1px;
    classDef database fill:#dfd,stroke:#333,stroke-width:1px;

    %% Node Mulai
    Start((Mulai)):::startEnd --> Login{Sudah Login?}:::decision

    %% Alur Login
    Login -- Belum --> FormLogin[Tampilkan Halaman Login]:::process
    FormLogin --> AuthCheck{Kredensial Valid?}:::decision
    AuthCheck -- Tidak --> FormLogin
    AuthCheck -- Ya --> RoleCheck{Cek Role}:::decision

    Login -- Sudah --> RoleCheck

    %% Percabangan Role
    RoleCheck -- Admin --> DashAdmin[Dashboard Admin\nManajemen Soal & Data]:::process
    RoleCheck -- Siswa --> DashSiswa[Dashboard Siswa\nBeranda Utama]:::process

    %% Alur Utama Siswa (Squad)
    DashSiswa --> CekKelas{Punya Kelas/Squad?}:::decision
    CekKelas -- Belum --> InputKode[Input Kode Kelas]:::process
    InputKode --> ValidasiKode{Kode Valid?}:::decision
    ValidasiKode -- Tidak --> InputKode
    ValidasiKode -- Ya --> JoinKelas[(Simpan ke Database\nclassroom_user)]:::database
    JoinKelas --> MenuUtama

    CekKelas -- Sudah --> MenuUtama[Menu Utama Siswa]:::process

    %% Pilihan Aktivitas Siswa
    MenuUtama --> PilihAktivitas{Pilih Aktivitas}:::decision

    %% Cabang 1: Materi
    PilihAktivitas -- Materi --> BukaMateri[Eksplorasi Materi]:::process
    BukaMateri --> CekStepMateri{Klik Elemen Interaktif?}:::decision
    CekStepMateri -- Ya --> SimpanAkt[(Update MaterialActivity)]:::database
    SimpanAkt --> CekTuntas{Step Selesai Semua?}:::decision
    CekTuntas -- Belum --> BukaMateri
    CekTuntas -- Ya --> SimpanTuntas[(Simpan MaterialCompletion)]:::database
    SimpanTuntas --> MenuUtama

    %% Cabang 2: Misi
    PilihAktivitas -- Misi --> BukaMisi[Pilih Kategori Misi]:::process
    BukaMisi --> TipeMisi{Tipe Misi?}:::decision

    %% Sub-Cabang Misi: Syntax
    TipeMisi -- Syntax --> KerjakanSyntax[Rakit Blok Rumus Excel]:::process
    KerjakanSyntax --> CekSyntax{Cocok dgn Kunci?}:::decision
    CekSyntax -- Salah --> HitungPenalti1[(Update Attempts)]:::database
    HitungPenalti1 --> KerjakanSyntax
    CekSyntax -- Benar --> HitungSkor1[(Update Skor Progress)]:::database
    HitungSkor1 --> SinkronXP[(Recalculate ScoresAndRanking)]:::database
    SinkronXP --> TampilSelesai[Tampilkan Badge Selesai]:::process
    TampilSelesai --> MenuUtama

    %% Sub-Cabang Misi: Point & Click
    TipeMisi -- Point/Click --> KlikSimulasi[Klik Area Gambar]:::process
    KlikSimulasi --> CekHotspot{Koordinat Benar?}:::decision
    CekHotspot -- Salah --> HitungPenalti2[(Update Attempts)]:::database
    HitungPenalti2 --> KlikSimulasi
    CekHotspot -- Benar --> CekStepMisi{Step Terakhir?}:::decision
    CekStepMisi -- Belum --> PindahStep[Tampilkan Langkah Baru]:::process
    PindahStep --> KlikSimulasi
    CekStepMisi -- Ya --> HitungSkor2[(Update Skor Progress)]:::database
    HitungSkor2 --> SinkronXP

    %% Cabang 3: Peringkat
    PilihAktivitas -- Peringkat --> TampilLeaderboard[Lihat Hall of Fame]:::process
    TampilLeaderboard --> PilihFilter{Global / Squad?}:::decision
    PilihFilter -- Global --> AmbilGlobal[(Query ScoresAndRanking)]:::database
    PilihFilter -- Squad --> AmbilSquad[(Query dengan Filter Kelas)]:::database
    AmbilGlobal --> TampilTabel[Render Tabel Peringkat]:::process
    AmbilSquad --> TampilTabel
    TampilTabel --> MenuUtama

    %% Node Selesai (Logout)
    MenuUtama --> Logout[Klik Logout]:::process
    Logout --> End((Selesai)):::startEnd