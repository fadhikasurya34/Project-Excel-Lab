sequenceDiagram
    autonumber
    actor User as Pengguna (Siswa/Admin)
    participant UI as Login View
    participant Auth as AuthController
    participant DB as User Model

    User->>UI: Input Email & Password
    UI->>Auth: POST /login (Credentials)
    Auth->>DB: Check email & Verify Hash
    
    alt Kredensial Valid (Email & Password Cocok)
        DB-->>Auth: Return User Object
        Auth->>Auth: Regenerate Session (Security)
        
        note over Auth,UI: Middleware Role Checker
        
        alt User Role == 'admin'
            Auth-->>UI: Redirect to route('admin.dashboard')
            UI-->>User: Render Dashboard Administrator
        else User Role == 'siswa'
            Auth-->>UI: Redirect to route('dashboard')
            UI-->>User: Render Beranda Virtual Lab
        end
        
    else Kredensial Tidak Valid (Gagal Login)
        DB-->>Auth: Return Null / False
        Auth-->>UI: Redirect Back (Error: Kredensial Salah)
        UI-->>User: Tampilkan Pesan "Login Gagal"
    end