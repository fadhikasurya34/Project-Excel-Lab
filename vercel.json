{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1",
            "includeFiles": "public/build/**"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/images/(.*)", "dest": "/public/images/$1" },
        { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp"
    }
}